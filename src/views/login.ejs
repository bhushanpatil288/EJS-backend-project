<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class=" bg-blue-200 ">
  <h2 class="text-center text-3xl font-bold my-30">Create an Account</h2>
  <div class="w-full min-h-screenpt-50">
    <form action="login" method="post" class="flex flex-col gap-3 items-center h-100 justify-center">
      <div>
        <input class="bg-blue-300 outline-none px-3 border-2 border-blue-400 py-1 rounded-md" type="email" name="email"
          placeholder="Enter email">
      </div>
      <div>
        <input class="bg-blue-300 outline-none px-3 border-2 border-blue-400 py-1 rounded-md" type="password"
          name="password" placeholder="Enter password">
      </div>
      <div>
        <button type="submit"
          class="bg-gradient-to-tr from-blue-500 to-blue-400 shadow px-3 py-1 rounded-md cursor-pointer text-white hover:scale-110 active:scale:95 transition-all transition-duration-300">Login</button>
      </div>
      <div class="flex flex-col items-center justify-center gap-3 mt-15">
        <p>Don't have an account? register instead </p>
        <a href="register"
          class="bg-gradient-to-tr from-blue-400 to-blue-500 shadow px-3 py-1 rounded-md cursor-pointer text-white hover:scale-110 active:scale:95 transition-all transition-duration-300">Register</a>
      </div>
  </form>
  </div>
</body>

</html>